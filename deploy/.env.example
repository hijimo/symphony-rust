# Symphony 部署配置
# 复制为 .env 后使用；install.sh 会自动生成密钥。

# === 必填：安全密钥（安装脚本自动生成，请勿手动填写弱值） ===
# 生成方式: openssl rand -base64 32
JWT_SECRET=
ENCRYPTION_KEY=

# === 可选：服务配置 ===
SERVER_PORT=3000
RUST_LOG=web_platform=info

# === 可选：AI 功能（不配置则禁用 AI Issue 生成） ===
# AZURE_OPENAI_BASEURL=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_MODEL=gpt-5.5

# === 可选：网络代理 ===
# HTTP_PROXY=http://proxy:port
# HTTPS_PROXY=http://proxy:port
# ALL_PROXY=socks5://proxy:port
