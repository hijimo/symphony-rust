# Symphony 测试环境变量
# 复制此文件为 .env 并填入实际值

# GitHub Token (需要 repo 权限)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitLab Token (需要 api 权限)
GITLAB_TOKEN=glpat-xxxxxxxxxxxx

# 测试仓库名 (owner/repo 格式，GitHub 和 GitLab 共用)
TEST_REPO_NAME=hijimo/symphony_e2e_test_repo

# GitLab 实例地址 (默认 https://gitlab.com)
# GITLAB_BASE_URL=https://gitlab.com
